{
	"name": "hlidskjalf",
	"version": "0.2.4",
	"description": "A Terminal User Interface for monitoring Turborepo tasks, built with Ink",
	"type": "module",
	"author": "Charlie Beckstrand",
	"license": "MIT",
	"keywords": [
		"turborepo",
		"monorepo",
		"terminal",
		"tui",
		"dev",
		"pnpm"
	],
	"engines": {
		"node": ">=22"
	},
	"bin": {
		"hlidskjalf": "dist/index.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"ink": "^5.2.1",
		"react": "^18.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/node": "^22.15.33",
		"@types/react": "^18.3.23",
		"lefthook": "^2.1.4",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}
