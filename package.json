{
	"name": "hlidskjalf",
	"version": "0.0.2",
	"description": "Terminal UI for monitoring Turborepo workspaces",
	"type": "module",
	"license": "MIT",
	"keywords": [
		"turborepo",
		"monorepo",
		"terminal",
		"tui",
		"dev",
		"pnpm"
	],
	"engines": {
		"node": ">=22"
	},
	"bin": {
		"hlidskjalf": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"format": "biome format --config-path=../.. --write ."
	},
	"dependencies": {
		"ink": "^5.2.1",
		"react": "^18.3.1"
	},
	"devDependencies": {
		"@types/node": "^22.15.33",
		"@types/react": "^18.3.23",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}
