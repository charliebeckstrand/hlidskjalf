{
	"name": "hlidskjalf",
	"version": "0.4.2",
	"description": "A Terminal User Interface for monitoring Turborepo tasks, built with Ink",
	"type": "module",
	"author": "Charlie Beckstrand",
	"license": "MIT",
	"keywords": [
		"turborepo",
		"monorepo",
		"terminal",
		"tui",
		"dev",
		"pnpm"
	],
	"packageManager": "pnpm@10.29.3",
	"engines": {
		"node": ">=22"
	},
	"bin": {
		"hlidskjalf": "dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/config.d.ts",
			"import": "./dist/config.js"
		}
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"bench": "tsx __benchmarks__/index.ts"
	},
	"dependencies": {
		"ink": "^5.2.1",
		"ink-spinner": "^5.0.0",
		"react": "^18.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/node": "^22.15.33",
		"@types/react": "^18.3.23",
		"lefthook": "^2.1.4",
		"tinybench": "^6.0.2",
		"tsup": "^8.5.1",
		"tsx": "^4.22.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.1"
	}
}
